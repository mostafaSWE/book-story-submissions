# Public Supabase project settings.
# These values are safe to use in browser/client contexts if needed.
PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
PUBLIC_SUPABASE_ANON_KEY="replace-with-supabase-anon-key"

# Server-only Supabase key. Never expose this in browser code.
SUPABASE_SERVICE_ROLE_KEY="replace-with-supabase-service-role-key"

# Public canonical site URL. Use the future custom domain in production.
SITE_URL="http://localhost:3000"

# Admin login. Use either ADMIN_USERNAME or ADMIN_EMAIL as the submitted username.
ADMIN_USERNAME="admin"
ADMIN_EMAIL=""
ADMIN_PASSWORD_HASH="replace-with-output-from-npm-run-admin-hash"
SESSION_SECRET="replace-with-a-long-random-production-secret"
